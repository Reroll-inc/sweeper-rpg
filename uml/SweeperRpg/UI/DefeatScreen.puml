@startuml
class DefeatScreen {
    + EnableDefeat() : void
    + <<override>> Input() : void
    + <<override>> Draw() : void
}
enum DefeatResult {
    Retry,
    MainMenu,
}
Node <|-- DefeatScreen
DefeatScreen o-> "bgImg" Image
DefeatScreen o-> "result" DefeatResult
DefeatScreen o-> "font" Font
DefeatScreen +-- DefeatResult
@enduml
